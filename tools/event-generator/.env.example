# Personal Access Token (classic). Required scopes:
#   - repo       (full control of private repos)
#   - workflow   (required to write .github/workflows/*.yml; covers workflow_run + workflow_job + check_suite + check_run events)
# Optional scope:
#   - user       (if star/unstar fails with the scopes above)
GITHUB_TOKEN=ghp_replace_me

# Repository the script operates on (owner/repo format). A webhook must
# already be configured on this repo pointing at your deployed receiver.
GITHUB_REPO=jamulasiva/webhook-receiver
