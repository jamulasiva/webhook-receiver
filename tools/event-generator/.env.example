# Personal Access Token (classic) with: repo, delete_repo
# Add admin:org if GITHUB_OWNER is an organization.
GITHUB_TOKEN=ghp_replace_me

# User or organization that will own the throwaway sandbox repository.
# Use a personal account or a dedicated sandbox org, NOT a production org.
GITHUB_OWNER=your-username-or-org

# Sandbox repo name prefix. A timestamp suffix is appended automatically so
# repeated runs do not collide.
SANDBOX_REPO_PREFIX=gitaudit-sandbox

# Delete the sandbox repo after the run completes? (true / false)
CLEANUP_AFTER_RUN=true
