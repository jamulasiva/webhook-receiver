# Local development environment for the webhook-receiver.
# `vercel dev` loads this file automatically. In production, set the same
# variables in the Vercel dashboard (Project Settings -> Environment Variables).

# Shared secret configured on the GitHub webhook. Generate a long random string
# and use the SAME value on both sides (this file + GitHub webhook config).
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-string

# Supabase project URL.
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase secret key (sb_secret_... or legacy service_role JWT). NOT the
# publishable key. Get it from Supabase -> Project Settings -> API -> Secret keys.
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-secret-key
